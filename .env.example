# Environment variables for the Cyber Incident Disclosure Tracker

# OpenAI API Key (if using OpenAI as AI provider)
# OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Anthropic API Key (if using Anthropic as AI provider)
# ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"

# GDELT API Key (if required for direct GDELT API access, though often GDELT is public data)
# GDELT_API_KEY="YOUR_GDELT_API_KEY"

# Database Configuration (Example for SQLite, adjust as needed)
# DATABASE_URL="sqlite:///./sql_app.db"

# CORS Origins for Frontend (e.g., http://localhost:3000)
# CORS_ORIGINS="http://localhost:3000"
