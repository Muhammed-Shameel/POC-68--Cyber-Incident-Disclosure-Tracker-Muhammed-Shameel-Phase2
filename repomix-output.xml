    # 2. Enrich (Classify & Score)
    df = enrich_incidents(df)
    
    # 3. Validate
    report = validate_data(df, dups)
    
    # 4. Save
    clean_path = save_clean_data(df)
    report_path = save_data_quality_report(report)
    
    print("\nPipeline completed successfully!")
