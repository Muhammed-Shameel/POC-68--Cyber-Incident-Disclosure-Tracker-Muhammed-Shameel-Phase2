        rule_based_insights=json.dumps(rule_based_insights, indent=2),
        trend_data=json.dumps(trend_data, indent=2)
    )
    
    provider = get_provider()
    return await provider.generate_text(prompt, system_prompt=SYSTEM_PROMPT)
