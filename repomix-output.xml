import { SectorIntelligence as SectorIntelligenceType } from '@/types';
import { PieChart, Pie, Cell, ResponsiveContainer, Tooltip, Legend } from 'recharts';

interface SectorExposurePanelProps {
  data: SectorIntelligenceType;
